# EditorConfig 统一编辑器基础设置
# 更多信息：https://editorconfig.org/

root = true

# 所有文件通用设置
[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

# Java 文件
[*.java]
indent_size = 4
indent_style = space
max_line_length = 120

# JavaScript / TypeScript / Vue 文件
[*.{js,ts,vue,jsx,tsx}]
indent_size = 2

# JSON / YAML 文件
[*.{json,yml,yaml}]
indent_size = 2

# Markdown 文件
[*.md]
trim_trailing_whitespace = false

# XML 文件
[*.xml]
indent_size = 4

# 属性文件
[*.properties]
indent_size = 0
end_of_line = crlf

# Makefile
[Makefile]
indent_style = tab
